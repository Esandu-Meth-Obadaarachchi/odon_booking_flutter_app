# ─── WhatsApp Business Cloud API ───────────────────────────────────────────
# Required for the "Send invoice on WhatsApp" feature.
# On Railway, set these in the project's Variables tab — do NOT commit a real .env.
# Copy this file to `.env` for local development only.

# Permanent access token from a Meta System User
# (Meta Business Settings -> Users -> System Users -> Generate token).
WHATSAPP_TOKEN=

# The Phone Number ID of your WhatsApp Cloud API number
# (WhatsApp Manager -> API Setup -> "Phone number ID").
WHATSAPP_PHONE_NUMBER_ID=

# Name of your approved message template.
WHATSAPP_TEMPLATE_NAME=invoice_send

# Language code the template was created in (e.g. en_US or en).
WHATSAPP_TEMPLATE_LANG=en_US

# Country code prepended to local guest numbers entered without one (Sri Lanka = 94).
WHATSAPP_DEFAULT_COUNTRY_CODE=94
